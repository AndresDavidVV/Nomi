generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── MODELO DVA: Descubrir · Validar · Activar ─────────────────

// Miembro del equipo Nomi (perfil extendido del User)
model TeamMember {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  rol       String   // EQUIPO_COMERCIAL, INVERSIONISTA, ALIADO_ESTRATEGICO, EQUIPO_INTERNO
  aporte    String?  // Cómo puede aportar al crecimiento de Nomi
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  oportunidades Oportunidad[]
}

// Establecimiento (restaurante, bar, hotel, etc.)
model Establecimiento {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  nombre        String
  tipo          String   // RESTAURANTE, CLUB, HOTEL, BAR, EXPERIENCIA_TURISTICA, OTRO
  tipoOtro      String?  // Si tipo es OTRO
  pais          String?
  ciudad        String?
  tamano        String?  // Tamaño aproximado
  
  // SEMÁFORO de completitud
  completitud   Int      @default(0)
  estadoFicha   String   @default("DESCUBRIR")  // DESCUBRIR, VALIDAR, ACTIVAR, CERRADO

  // OWNERSHIP
  creadoPorId   String?
  creadoPor     User?    @relation(fields: [creadoPorId], references: [id])

  // RELACIONES
  contactos     Contacto[]
  oportunidades Oportunidad[]
}

// Contacto dentro del establecimiento
model Contacto {
  id                String          @id @default(uuid())
  establecimientoId String
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  
  nombre            String
  cargo             String?
  telefono          String?
  email             String?
  esDecisor         Boolean         @default(false)  // ¿Toma decisiones de tecnología?
  
  createdAt         DateTime        @default(now())
}

// Oportunidad (el corazón del funnel DVA)
model Oportunidad {
  id                String          @id @default(uuid())
  establecimientoId String
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  
  // Quién registró esta oportunidad
  registradoPorId   String?
  registradoPor     TeamMember?     @relation(fields: [registradoPorId], references: [id])
  
  // ── ETAPA 1: DESCUBRIR ──
  comoConocio       String?  // REFERIDO, VISITA, SOCIO, EVENTO, INVESTIGACION, OTRO
  hipotesisValor    String?  // Cómo crees que Nomi podría encajar aquí
  nivelPotencial    String?  // ALTO, MEDIO, BAJO
  
  // ── ETAPA 2: VALIDAR ──
  pedidosMes        Int?     // Pedidos aproximados por mes
  puntoExigente     String?  // Qué parte del servicio es más compleja
  valorNomi         String?  // Dónde Nomi aporta más valor
  nivelInteres      String?  // ALTO, MEDIO, BAJO
  
  // ── ETAPA 3: ACTIVAR ──
  confirmacionInteres String?  // SI_AVANZAR, INTERES_ALTO_REVISANDO, INTERES_MEDIO, NO_POR_AHORA
  siguientePaso       String?  // REUNION_TECNICA, REVISION_COMERCIAL, PRESENTACION_JUNTA, DEFINICION_FECHAS
  
  // Propuesta comercial
  valorPropuesto      String?
  alcanceImplementacion String?
  condiciones         String?
  
  // Negociación
  fechaSeguimiento    DateTime?
  comentariosCliente  String?
  ajustesSolicitados  String?
  probabilidadCierre  String?  // ALTA, MEDIA, BAJA
  
  // Cierre
  resultadoFinal      String?  // VENTA_CERRADA, EN_PAUSA, DESCARTADA
  
  // Estado general del funnel
  etapaActual         String   @default("DESCUBRIR")  // DESCUBRIR, VALIDAR, ACTIVAR, CERRADO
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  seguimientos        Seguimiento[]
  
  @@index([etapaActual])
  @@index([establecimientoId])
}

// Seguimiento de una oportunidad
model Seguimiento {
  id             String      @id @default(uuid())
  oportunidadId  String
  oportunidad    Oportunidad @relation(fields: [oportunidadId], references: [id])
  
  accion         String
  resultado      String?
  fecha          DateTime    @default(now())
  
  creadoPorId    String?
  creadoPor      User?       @relation(fields: [creadoPorId], references: [id])
}

// ── AUTH MODELS ────────────────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  phone         String         @unique
  name          String?
  email         String?
  role          String         @default("USER")  // USER, ADMIN
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  teamMember    TeamMember?
  establecimientos Establecimiento[]
  seguimientos  Seguimiento[]
  conversations Conversation[]
  feedbacks     Feedback[]
}

model OTPCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([phone, expiresAt])
}

// ── CONVERSATION MODELS ────────────────────────────────────────

model Conversation {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  title         String    @default("Nueva conversación")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime  @default(now())
  
  messages      Message[]
  
  @@index([userId, lastMessageAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role           String       // 'user' or 'assistant'
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  
  @@index([conversationId, createdAt])
}

model Feedback {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  conversationId String?
  
  rating         Int          // 1-5
  comment        String?      @db.Text
  status         String       @default("pending")
  adminNote      String?      @db.Text
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  
  @@index([userId])
  @@index([rating])
  @@index([status])
  @@index([createdAt])
}
